# ─── terraform/.gitignore ─────────────────────────────────────────────────────

# Your actual secret values — NEVER commit this
terraform.tfvars

# Terraform state — contains real infrastructure details
# If lost, terraform loses track of what exists
# Store in S3 for teams (see backend config in main.tf)
*.tfstate
*.tfstate.backup
*.tfstate.*.backup

# Terraform working directory — downloaded providers
# Large files, regenerated by terraform init
.terraform/

# NOTE: .terraform.lock.hcl is intentionally NOT ignored
# It pins provider versions — commit it like package-lock.json

# Crash logs
crash.log
crash.*.log

# Override files — local developer customizations
override.tf
override.tf.json
*_override.tf
*_override.tf.json
